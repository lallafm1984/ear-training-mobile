{
  "expo": {
    "name": "MelodyGen",
    "slug": "melodygen",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f8fafc"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.melodygen.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "오디오 재생에 필요합니다."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#EEF1FB"
      },
      "package": "com.melodygen.app",
      "versionCode": 2,
      "permissions": [
        "READ_MEDIA_AUDIO",
        "WRITE_EXTERNAL_STORAGE",
        "READ_EXTERNAL_STORAGE",
        "com.android.vending.BILLING"
      ],
      "predictiveBackGestureEnabled": false,
      "navigationBarColor": "#f8fafc"
    },
    "scheme": "melodygen",
    "plugins": [
      "expo-secure-store",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "a5fc0b5c-a19c-461e-a2b8-7f654f22496a"
      }
    },
    "owner": "lallafm"
  }
}